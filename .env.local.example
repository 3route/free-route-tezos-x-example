# Copy to `.env.local`. All values have working previewnet defaults in lib/config.ts —
# only override if you point at a different deployment / 3route server.

# 3route server base URL — used SERVER-SIDE by the /api/3route handlers (avoids browser CORS).
THREE_ROUTE_API=http://127.0.0.1:3000

# 3route HTTP Basic api key — SERVER-ONLY (note: NOT NEXT_PUBLIC_*). The proxy injects it; the browser never
# sees it. Leave unset for the keyless local dev server.
THREE_ROUTE_API_KEY=YourApiKey

# Public previewnet wiring (browser-visible). Defaults live in lib/config.ts.
NEXT_PUBLIC_TEZ_RPC=https://michelson.previewnet.tezosx.nomadic-labs.com
NEXT_PUBLIC_EVM_RPC=https://evm.previewnet.tezosx.nomadic-labs.com
NEXT_PUBLIC_TZKT_API=https://api.previewnet.tezosx.tzkt.io/v1
NEXT_PUBLIC_EVM_EXPLORER=https://blockscout.previewnet.tezosx.nomadic-labs.com
NEXT_PUBLIC_CHAIN_ID=128064
NEXT_PUBLIC_GATEWAY=KT18oDJJKXMKhfE1bSuAPGp92pYcwVDiqsPw
NEXT_PUBLIC_OBJKT=KT1AyJ5P4qRJZuHqXiR9QkKRuCy49yNyLVzo
NEXT_PUBLIC_FA2=KT1TGSPo2Z8MJtCpNe2VmuuMaUJd8cbWLeLp
